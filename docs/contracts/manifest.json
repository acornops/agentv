{
  "repo": "vm-agent",
  "version": 1,
  "runtimeDependencies": ["control-plane"],
  "counterparts": {
    "control-plane": {
      "websocketPaths": ["/api/v1/agent/connect", "/agent/v1/connect"],
      "agentHeaders": ["x-agent-key", "x-agent-version"],
      "handshakeRequestFields": [
        "agentKey",
        "agentId",
        "agentVersion",
        "targetId",
        "targetType",
        "agentType",
        "supportedCapabilities",
        "osFamily",
        "serviceManager"
      ],
      "handshakeResponseFields": [
        "workspaceId",
        "targetId",
        "targetType",
        "sessionPolicy.allowedTools",
        "sessionPolicy.writeEnabled",
        "config.snapshotInterval",
        "config.maxSnapshotBytes"
      ],
      "snapshotFields": [
        "targetId",
        "targetType",
        "capturedAt",
        "host",
        "resources.processes[]",
        "resources.services[]",
        "resources.ports[]",
        "findings[]",
        "metrics"
      ],
      "rpcMethods": ["tools/list", "tools/call"],
      "builtinToolNames": [
        "get_host_summary",
        "list_processes",
        "get_process",
        "list_services",
        "get_service_status",
        "get_logs",
        "search_logs",
        "check_port",
        "list_listening_ports"
      ]
    }
  }
}
