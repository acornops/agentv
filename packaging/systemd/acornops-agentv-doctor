#!/usr/bin/env bash
set -euo pipefail

if [[ ! -r /etc/acornops/agentv.env ]]; then
  echo "Cannot read /etc/acornops/agentv.env; run with sudo or as acornops-agent." >&2
  exit 1
fi
set -a
# The file is installed root-owned and is the same trusted environment source
# consumed by systemd for the main service.
# shellcheck source=/dev/null
source /etc/acornops/agentv.env
set +a
if [[ "$(id -u)" -eq 0 ]]; then
  exec /usr/sbin/runuser --preserve-environment --user acornops-agent -- /usr/bin/node /opt/acornops/agentv/current/dist/index.js doctor "$@"
fi
if [[ "$(id -un)" != "acornops-agent" ]]; then
  echo "Run with sudo so checks execute as the acornops-agent service user." >&2
  exit 1
fi
exec /usr/bin/node /opt/acornops/agentv/current/dist/index.js doctor "$@"
